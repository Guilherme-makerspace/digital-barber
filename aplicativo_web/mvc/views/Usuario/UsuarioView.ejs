<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SGP - Dashboard Usuário</title>
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Nunito:wght@300;400;600;700&display=swap');

        :root {
            --bg-body: #262626;
            --bg-sidebar: #1f1f1f;
            --bg-card: #303030;
            --primary: #686868;
            --accent: #004ba8;
            --text-main: #ffffff;
            --text-muted: #a1a0a0;
            --border-radius: 8px;
            --font: "Nunito", sans-serif;
            --sidebar-width: 60px;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            background-color: var(--bg-body);
            color: var(--text-main);
            font-family: var(--font);
            display: flex;
            height: 100vh;
            overflow: hidden;
        }

        /* --- Sidebar Modular --- */
        .lg-sidebar {
            width: var(--sidebar-width);
            background-color: var(--bg-sidebar);
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 20px 0;
            flex-shrink: 0;
        }

        .lg-nav-item svg { 
            width: 20px; 
            height: 20px; 
        }

        .lg-nav-item {
            color: var(--text-muted);
            padding: 12px;
            margin-bottom: 8px;
            border-radius: 4px;
            transition: all 0.2s ease;
            display: flex; align-items: center;
        }

        .lg-nav-item:hover, .lg-nav-item.active {
            background-color: rgba(255, 255, 255, 0.05);
            color: var(--text-main);
        }

        /* --- Layout Principal --- */
        .lg-main-container {
            flex-grow: 1;
            padding: 40px;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 24px;
        }

        /* --- Breadcrumb --- */
        .lg-breadcrumb {
            display: flex; gap: 8px; font-size: 11px;
            text-transform: uppercase; letter-spacing: 1px;
            color: var(--text-muted);
            align-items: center;
        }
        .lg-breadcrumb b { color: var(--text-main); }
        .lg-breadcrumb span::after { 
            content: '/'; 
            margin-left: 8px; 
        }
        /* --- Área de Saudação --- */
        .lg-greeting-box {
            display: flex;
            flex-direction: column;
            gap: 8px;
            max-width: 800px;
        }

        .lg-display-1 { font-size: 32px; font-weight: 700; color: var(--text-main); }
        .lg-display-2 { font-size: 16px; color: var(--text-muted); line-height: 1.6; }

        /* --- Card de Resumo --- */
        .lg-summary-card {
            margin-top: 20px;
            padding: 24px;
            border-radius: var(--border-radius);
            background: var(--bg-sidebar);
            border: 1px solid rgba(255, 255, 255, 0.05);
            width: fit-content;
            min-width: 300px;
        }

        .lg-summary-card h3 {
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 16px;
            color: var(--accent);
            font-weight: 700;
        }

        .lg-summary-item {
            display: flex;
            justify-content: space-between;
            margin-bottom: 8px;
            font-size: 14px;
        }

        .lg-summary-label { color: var(--primary); }
        .lg-summary-value { color: var(--text-muted); font-weight: 600; }

    </style>
</head>

<body>
    <nav class="lg-sidebar">
        <a href="/user/" class="lg-nav-item active"><i data-lucide="layout-grid"></i></a>
        <a href="/atendimento/list" class="lg-nav-item"><i data-lucide="calendar-search"></i></a>
        <a href="/professionals/" class="lg-nav-item"><i data-lucide="user"></i></a>
        <div style="flex-grow: 1;"></div>
        <a href="/logout" class="lg-nav-item"><i data-lucide="log-out"></i></a>
    </nav>


    <main class="lg-main-container">
        <div class="lg-breadcrumb">
            <span>Portal</span>
            <b>Dashboard</b>
        </div>

        <div class="lg-greeting-box">
            <h1 class="lg-display-1" id="saudacaoTexto">Carregando...</h1>
            <p class="lg-display-2">
                Bem-vindo de volta ao sistema. Todas as suas ferramentas de gerenciamento 
                e configurações de perfil estão prontas para o uso.
            </p>
            
            <div class="lg-summary-card">
                <h3>Resumo da Conta</h3>
                
                <div class="lg-summary-item">
                    <span class="lg-summary-label">Status</span>
                    <span class="lg-summary-value" style="color: #ffffff;">Ativo</span>
                </div>
                
                <div class="lg-summary-item">
                    <span class="lg-summary-label">Último Acesso</span>
                    <span class="lg-summary-value">Hoje, 14:30</span>
                </div>

                <div class="lg-summary-item">
                    <span class="lg-summary-label">Nível de Acesso</span>
                    <span class="lg-summary-value">Administrador</span>
                </div>
            </div>
        </div>
    </main>

    <script>
        lucide.createIcons();

        // Lógica de Saudação Automática
        function atualizarSaudacao() {
            const hora = new Date().getHours();
            const texto = document.getElementById('saudacaoTexto');
            let saudacao = "";

            if (hora >= 5 && hora < 12) saudacao = "Bom dia";
            else if (hora >= 12 && hora < 18) saudacao = "Boa tarde";
            else saudacao = "Boa noite";

            // Aqui você pode substituir "Usuário" pelo nome vindo do seu backend
            texto.innerText = `${saudacao}, Usuário!`;
        }

        atualizarSaudacao();
    </script>
</body>
</html>
